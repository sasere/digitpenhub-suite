NODE_ENV=production
PORT=4001

# Postgres connection for this app's own database (separate from PAMCET's pamc_lmsdb / slid_slidegen)
DATABASE_URL=postgres://digitpenhub_suite:CHANGE_ME@127.0.0.1:5432/digitpenhub_suite

# Long random string. Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME

# Optional: enables real generation in AI Writer, AI Email Assistant, AI Proposal Generator, and AI Blog Generator.
GEMINI_API_KEY=

# Optional: shared stock-photo sourcing for template libraries and image search.
PEXELS_API_KEY_1=
PEXELS_API_KEY_2=
PEXELS_API_KEY_3=
PEXELS_API_KEY_4=
PEXELS_API_KEY_5=
PEXELS_API_KEY_6=
PEXELS_API_KEY_7=

# Only the Next.js frontend should ever call this API directly cross-origin (local dev).
# In production the frontend proxies same-origin, so this mostly matters for local testing.
FRONTEND_ORIGIN=http://localhost:4000

# Used once by db/seed.js to create the first owner account. Change the password after first login.
ADMIN_NAME=Sasere Michael Olusola
ADMIN_EMAIL=sasere@digitpenhub.com
ADMIN_PASSWORD=CHANGE_ME
